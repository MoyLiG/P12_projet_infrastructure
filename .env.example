# =====================================================================
# Sport Data Solution — POC Avantages Sportifs
# Template de configuration. Copier en `.env` et remplir les valeurs.
# Ne jamais committer le .env.
# =====================================================================

# --- PostgreSQL ---------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sport_data
POSTGRES_USER=etl_writer
POSTGRES_PASSWORD=change-me-please-strong-pwd
POSTGRES_SUPERUSER_PASSWORD=change-me-too-strong-pwd

# --- Kestra -------------------------------------------------------------
KESTRA_URL=http://kestra:8080
KESTRA_NAMESPACE=company.sport_data

# --- Google Maps Distance Matrix API ------------------------------------
# Clé créée sur console.cloud.google.com (forfait gratuit ~40k req/mois)
# Restreindre la clé à l'API "Distance Matrix" depuis la console Google.
GOOGLE_MAPS_API_KEY=AIzaSy...

# Adresse de l'entreprise (Sport Data Solution)
COMPANY_ADDRESS=1362 Avenue des Platanes, 34970 Lattes, France

# --- Slack Incoming Webhook --------------------------------------------
# Créer sur api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_CHANNEL=#sport-data

# --- Alertes mail Kestra (errors:) -------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=app-password-here
ALERT_RECIPIENT=morgan@example.com

# --- Paramètres métier (modifiables sans toucher au code) --------------
# Pris par défaut par Kestra ; le flow accepte des overrides en input.
PRIME_RATE_DEFAULT=0.05                # 5 % du salaire annuel brut
WELLBEING_ACTIVITY_THRESHOLD=15        # nb min d'activités / an
WALKING_MAX_KM=15
CYCLING_MAX_KM=25

# --- Générateur d'activités --------------------------------------------
ACTIVITIES_SEED=42                     # reproductibilité
ACTIVITIES_TOTAL=4000                  # ~3-5k attendu

# --- Hashing PII (pseudonymisation rôle analyste) ----------------------
# Sel salé qui change entre dev/prod ; long, aléatoire, jamais committé.
PII_HASH_SALT=replace-with-32-random-bytes-base64

# --- Secrets encodés base64 pour Kestra --------------------------------
# Kestra v0.19 lit les secrets via des env SECRET_* dont la valeur DOIT être
# encodée en base64. Ces variantes sont régénérées par scripts/gen_secrets_b64.py
# (ou à la main : echo -n "valeur" | base64). Le docker-compose les injecte
# dans le conteneur Kestra. Ne pas committer le .env réel.
SECRET_DB_PASSWORD_B64=
SECRET_GOOGLE_MAPS_API_KEY_B64=
SECRET_SLACK_WEBHOOK_URL_B64=
SECRET_PII_HASH_SALT_B64=
